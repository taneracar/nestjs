{
  "info": {
    "name": "User CRUD",
    "schema": "https://schema.get3postman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "userId", "value": "1" }
  ],
  "item": [
    {
      "name": "Get all users",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/user", "host": ["{{baseUrl}}"], "path": ["user"] }
      }
    },
    {
      "name": "Get users filtered by name",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/user?name=jen",
          "host": ["{{baseUrl}}"],
          "path": ["user"],
          "query": [{ "key": "name", "value": "jen" }]
        }
      }
    },
    {
      "name": "Get user by id",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/user/{{userId}}", "host": ["{{baseUrl}}"], "path": ["user", "{{userId}}"] }
      }
    },
    {
      "name": "Create user",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Nova\",\n  \"email\": \"nova@example.com\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/user", "host": ["{{baseUrl}}"], "path": ["user"] }
      }
    },
    {
      "name": "Update user",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Nova Updated\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/user/{{userId}}", "host": ["{{baseUrl}}"], "path": ["user", "{{userId}}"] }
      }
    },
    {
      "name": "Delete user",
      "request": {
        "method": "DELETE",
        "url": { "raw": "{{baseUrl}}/user/{{userId}}", "host": ["{{baseUrl}}"], "path": ["user", "{{userId}}"] }
      }
    }
  ]
}
